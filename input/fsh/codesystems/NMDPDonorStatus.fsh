CodeSystem: NMDPDonorStatusCS
Id: nmdp-donor-status
Title: "NMDP Donor Status"
Description: "Status codes for NMDP registered donors."
* ^caseSensitive = true
* ^content = #complete
* #active "Active" "The donor is currently active and available in the registry."
* #inactive "Inactive" "The donor is no longer active in the registry."
* #deferred "Deferred" "The donor is temporarily deferred from donation."
* #unavailable "Unavailable" "The donor is unavailable for donation."
